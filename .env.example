# Copy this file to .env and fill in your own values.
# The .env file is gitignored — never commit real secrets.

# ---- Branding ----
# Shown in the bot's greeting and system prompt. Rename to whatever you like.
PROJECT_NAME=Stratum
# Contact the bot points users to when it doesn't know the answer.
SUPPORT_EMAIL=support@example.com

# ---- Database (PostgreSQL) ----
DB_NAME=stratum
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ---- Widget auth ----
# API key the embeddable chat widget sends as a Bearer token. Injected into
# chatbot.js at serve time so it isn't committed in the JS source.
# Generate one with: python -c "import secrets;print('sk-'+secrets.token_hex(32))"
CHATBOT_API_KEY=sk-change-me

# ---- Admin panel ----
# Default admin account seeded on first startup. Change the password after first login.
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe!123

# Signing key for admin session tokens. Keep this stable & secret so logins
# survive server restarts. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
# How long an admin stays logged in, in seconds (default 12h).
SESSION_TTL_SECONDS=43200

# ---- LLM / Ollama ----
# Change the model here without touching any code. Must be a model you have
# pulled in Ollama (run: ollama list). Examples: llama3.2:latest, qwen2.5:7b, mistral:latest
DEFAULT_GENERATION_MODEL=llama3.2:latest
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# ---- Document vision / OCR ----
# Ollama vision model used to deep-scan rich pages (tables, charts, scanned pages).
# Pull it with: ollama pull glm-ocr
# If it isn't pulled, ingestion falls back to Tesseract, then to the PDF text layer.
OCR_MODEL=glm-ocr:latest
# Render resolution for pages sent to the vision model (150 dpi = sharp + fast).
OCR_PAGE_DPI=150
# Per-page ceiling for a vision call, in seconds.
OCR_TIMEOUT_SECONDS=120

# ---- Uploads ----
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,txt
